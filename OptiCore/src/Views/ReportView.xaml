<UserControl x:Class="OptiCore.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Report_Title}" FontFamily="Segoe UI Semibold" FontSize="20" Foreground="#e6edf3" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyButton" Content="{DynamicResource Report_CopyButton}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="CopyButton_Click"/>
                <Button x:Name="ExportTxtButton" Content="{DynamicResource Report_ExportTXT}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="ExportTxtButton_Click"/>
                <Button x:Name="ExportPdfButton" Content="{DynamicResource Report_ExportPDF}" Style="{StaticResource PrimaryButton}" Click="ExportPdfButton_Click"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ReportPanel"/>
        </ScrollViewer>

        <TextBlock Grid.Row="2" x:Name="GeneratedAt" FontFamily="Segoe UI" FontSize="11" Foreground="#8b949e" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
