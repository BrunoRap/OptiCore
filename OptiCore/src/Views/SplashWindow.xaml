<Window x:Class="OptiCore.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OptiCore" Height="680" Width="560"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Outer Grid: lets the close button float over the rounded border -->
    <Grid>

        <!-- Main card -->
        <Border Background="#0d1117" CornerRadius="12" BorderBrush="#30363d" BorderThickness="1">
            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" Width="120" Height="120" CornerRadius="60"
                        Background="#161b22" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Grid>
                        <Image x:Name="LogoImage" Source="/src/Assets/BTT.png" Stretch="Uniform"
                               Width="100" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LogoFallback" Text="BTT" FontFamily="Segoe UI Semibold"
                                   FontSize="36" Foreground="#c0392b"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Title -->
                <TextBlock Grid.Row="1" Text="OptiCore" FontFamily="Segoe UI Semibold"
                           FontSize="32" Foreground="#e6edf3"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>

                <!-- Subtitle -->
                <TextBlock Grid.Row="2" Text="Windows Performance Optimizer"
                           FontFamily="Segoe UI" FontSize="14" Foreground="#8b949e"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Message -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                    <TextBlock x:Name="MessageText"
                               TextWrapping="Wrap" TextAlignment="Center"
                               FontFamily="Segoe UI" FontSize="12" Foreground="#8b949e"
                               LineHeight="20"/>
                </ScrollViewer>

                <!-- Donation area -->
                <StackPanel Grid.Row="4" Margin="0,20,0,12" HorizontalAlignment="Center">
                    <TextBlock Text="If OptiCore helped you, consider a donation:"
                               FontFamily="Segoe UI" FontSize="11" Foreground="#8b949e"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="KofiButton" Content="☕  Support on Ko-fi"
                                Width="160" Height="34" Margin="0,0,12,0"
                                Background="#ff5e5b" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontFamily="Segoe UI Semibold" FontSize="12"
                                Click="KofiButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="12,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="PIX (Brazil): 09794587737"
                               FontFamily="Segoe UI" FontSize="11" Foreground="#8b949e"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Language Selector -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="Language: " FontFamily="Segoe UI" FontSize="12" Foreground="#8b949e"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <!--
                        Background/Foreground are light so the OS popup is readable.
                        Item foreground is set explicitly in code-behind.
                    -->
                    <ComboBox x:Name="LanguageCombo" Width="140"
                              Background="#f5f5f5" Foreground="#111111"
                              BorderBrush="#30363d" FontFamily="Segoe UI" FontSize="12"
                              SelectionChanged="LanguageCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Continue Button -->
                <Button Grid.Row="6" x:Name="ContinueButton" IsEnabled="False"
                        Width="200" Height="42" HorizontalAlignment="Center"
                        Background="#c0392b" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontFamily="Segoe UI Semibold" FontSize="14"
                        Click="ContinueButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Background" Value="#444"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#e74c3c"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Version -->
                <TextBlock Grid.Row="7" Text="v1.5.0 — © 2026 Brazilian Top Team"
                           FontFamily="Segoe UI" FontSize="10" Foreground="#444"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </Grid>
        </Border>

        <!-- Close button — floats over the card at top-right -->
        <Button x:Name="CloseButton"
                Width="28" Height="28"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,10,10,0"
                Cursor="Hand"
                Click="CloseButton_Click"
                ToolTip="Close">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="4"
                            Background="Transparent"
                            BorderThickness="0">
                        <TextBlock Text="✕" FontSize="13" FontFamily="Segoe UI"
                                   Foreground="#8b949e"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#c0392b"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</Window>
