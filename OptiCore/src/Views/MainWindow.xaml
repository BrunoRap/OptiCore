<Window x:Class="OptiCore.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OptiCore — Windows Performance Optimizer"
        MinWidth="1200" MinHeight="800"
        Width="1280" Height="860"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117"
        Style="{StaticResource AppWindowStyle}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Header -->
                <StackPanel Grid.Row="0" Margin="16,24,16,24">
                    <TextBlock Text="OptiCore" FontFamily="Segoe UI Semibold" FontSize="22"
                               Foreground="#e6edf3"/>
                    <TextBlock Text="Performance Optimizer" FontFamily="Segoe UI" FontSize="11"
                               Foreground="#8b949e" Margin="0,2,0,0"/>
                    <TextBlock Text="v1.5.0" FontFamily="Segoe UI" FontSize="10"
                               Foreground="#444" Margin="0,2,0,0"/>
                </StackPanel>

                <Separator Grid.Row="0" Background="#30363d" Margin="0,70,0,0" VerticalAlignment="Bottom"/>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <Button x:Name="NavHardware" Style="{StaticResource NavigationButtonActive}"
                            Height="44" Click="NavHardware_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖥  " VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Hardware}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavOptimize" Style="{StaticResource NavigationButton}"
                            Height="44" Click="NavOptimize_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡  " VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Optimize}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavValidate" Style="{StaticResource NavigationButton}"
                            Height="44" Click="NavValidate_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓  " VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Validate}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavRollback" Style="{StaticResource NavigationButton}"
                            Height="44" Click="NavRollback_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↩  " VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Rollback}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavReport" Style="{StaticResource NavigationButton}"
                            Height="44" Click="NavReport_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊  " VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Report}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavBenchmark" Style="{StaticResource NavigationButton}"
                            Height="44" Click="NavBenchmark_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏱  " VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Benchmark}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavAbout" Style="{StaticResource NavigationButton}"
                            Height="44" Click="NavAbout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ  " VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_About}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Bottom: Logo + Donate -->
                <StackPanel Grid.Row="2" Margin="16,0,16,16">
                    <Separator Background="#30363d" Margin="0,0,0,12"/>
                    <Button Click="LogoBtn_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="18" Background="#21262d">
                                <Grid>
                                    <Image Source="/src/Assets/BTT.png" Stretch="Uniform" Width="30" Height="30"/>
                                    <TextBlock Text="BTT" FontFamily="Segoe UI Semibold" FontSize="10"
                                               Foreground="#c0392b" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Brazilian Top Team" FontSize="11" Foreground="#8b949e"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Content Area -->
            <ContentControl Grid.Row="0" x:Name="MainContent" Margin="24,24,24,0"/>

            <!-- Status Bar -->
            <Border Grid.Row="1" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="16,8">
                <Grid>
                    <TextBlock x:Name="StatusText" Text="Ready"
                               FontFamily="Segoe UI" FontSize="12" Foreground="#8b949e"
                               VerticalAlignment="Center"/>
                    <Button x:Name="DonateButton" Content="☕ Donate" HorizontalAlignment="Right"
                            Background="Transparent" BorderBrush="#30363d" BorderThickness="1"
                            Foreground="#8b949e" Padding="10,4" Cursor="Hand"
                            FontFamily="Segoe UI" FontSize="11" Click="DonateButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
