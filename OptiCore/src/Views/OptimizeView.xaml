<UserControl x:Class="OptiCore.Views.OptimizeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header + Scan button -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Optimize_Title}" FontFamily="Segoe UI Semibold" FontSize="20" Foreground="#e6edf3" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SelectAllButton" Content="{DynamicResource Optimize_SelectAllSafe}" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0" Click="SelectAllButton_Click"/>
                <Button x:Name="DeselectAllButton" Content="{DynamicResource Optimize_DeselectAll}" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0" Click="DeselectAllButton_Click"/>
                <Button x:Name="ScanButton" Content="{DynamicResource Optimize_ScanButton}" Style="{StaticResource PrimaryButton}"
                        Click="ScanButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Compat Banner -->
        <Border Grid.Row="1" x:Name="CompatBanner" CornerRadius="6" Padding="12,8" Margin="0,0,0,12" Visibility="Collapsed">
            <TextBlock x:Name="CompatText" TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12" Foreground="White"/>
        </Border>

        <!-- Filter Bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Filter: " FontFamily="Segoe UI" FontSize="12" Foreground="#8b949e" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button x:Name="FilterAll" Content="{DynamicResource Optimize_FilterAll}" Style="{StaticResource SecondaryButton}" Padding="12,5" Margin="0,0,4,0" Click="FilterAll_Click"/>
            <Button x:Name="FilterHigh" Content="{DynamicResource Optimize_FilterHigh}" Style="{StaticResource SecondaryButton}" Padding="12,5" Margin="0,0,4,0" Click="FilterHigh_Click"/>
            <Button x:Name="FilterReboot" Content="{DynamicResource Optimize_FilterReboot}" Style="{StaticResource SecondaryButton}" Padding="12,5" Margin="0,0,4,0" Click="FilterReboot_Click"/>
            <Button x:Name="FilterSafe" Content="{DynamicResource Optimize_FilterSafe}" Style="{StaticResource SecondaryButton}" Padding="12,5" Click="FilterSafe_Click"/>
        </StackPanel>

        <!-- Progress area -->
        <Border Grid.Row="3" x:Name="ProgressArea" Visibility="Collapsed" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="ProgressLabel" FontFamily="Segoe UI" FontSize="12" Foreground="#e6edf3" Margin="0,0,0,6"/>
                <ProgressBar x:Name="ProgressBar" Style="{StaticResource AccentProgressBar}" Minimum="0" Maximum="100"/>
                <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="11" Foreground="#8b949e" TextWrapping="Wrap"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Optimizations List -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="OptimizationsPanel"/>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <TextBlock x:Name="ScanHint" Text="{DynamicResource Optimize_ScanHint}"
                       FontFamily="Segoe UI" FontSize="12" Foreground="#8b949e" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ViewReportButton" Content="{DynamicResource Optimize_ViewReport}" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0" Visibility="Collapsed" Click="ViewReportButton_Click"/>
                <Button x:Name="ApplyButton" Content="Apply Selected (0)" Style="{StaticResource PrimaryButton}"
                        IsEnabled="False" Click="ApplyButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
