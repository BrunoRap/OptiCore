<UserControl x:Class="OptiCore.Views.HardwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{DynamicResource Hardware_Title}"
                   FontFamily="Segoe UI Semibold" FontSize="20"
                   Foreground="#e6edf3" Margin="0,0,0,16"/>

        <!-- Compatibility Banner -->
        <Border Grid.Row="1" x:Name="CompatBanner" CornerRadius="6" Padding="16,10" Margin="0,0,0,16">
            <TextBlock x:Name="CompatText" TextWrapping="Wrap"
                       FontFamily="Segoe UI Semibold" FontSize="13" Foreground="White"/>
        </Border>

        <!-- Hardware Cards Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="CardsGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- CPU Card -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Hardware_CPU}" Style="{StaticResource SubHeaderText}" Margin="0,0,0,8"/>
                        <Separator Style="{StaticResource DarkSeparator}"/>
                        <StackPanel x:Name="CpuPanel" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- GPU Card -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="8,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Hardware_GPU}" Style="{StaticResource SubHeaderText}" Margin="0,0,0,8"/>
                        <Separator Style="{StaticResource DarkSeparator}"/>
                        <StackPanel x:Name="GpuPanel" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- RAM Card -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Hardware_RAM}" Style="{StaticResource SubHeaderText}" Margin="0,0,0,8"/>
                        <Separator Style="{StaticResource DarkSeparator}"/>
                        <StackPanel x:Name="RamPanel" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- NIC Card -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="8,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Hardware_NIC}" Style="{StaticResource SubHeaderText}" Margin="0,0,0,8"/>
                        <Separator Style="{StaticResource DarkSeparator}"/>
                        <StackPanel x:Name="NicPanel" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- USB Card -->
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Hardware_USB}" Style="{StaticResource SubHeaderText}" Margin="0,0,0,8"/>
                        <Separator Style="{StaticResource DarkSeparator}"/>
                        <StackPanel x:Name="UsbPanel" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- System Card -->
                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="8,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Hardware_OS}" Style="{StaticResource SubHeaderText}" Margin="0,0,0,8"/>
                        <Separator Style="{StaticResource DarkSeparator}"/>
                        <StackPanel x:Name="SysPanel" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
