<UserControl x:Class="OptiCore.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Center" MaxWidth="600" Margin="0,20,0,40">

            <!-- Logo -->
            <Border Width="160" Height="160" CornerRadius="80" Background="#161b22"
                    HorizontalAlignment="Center" Margin="0,0,0,24">
                <Grid>
                    <Image Source="/src/Assets/BTT.png" Stretch="Uniform" Width="140" Height="140">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Text="BTT" FontFamily="Segoe UI Semibold" FontSize="48" Foreground="#c0392b"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TextBlock Text="OptiCore" FontFamily="Segoe UI Semibold" FontSize="32"
                       Foreground="#e6edf3" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="v1.6.0 — Windows Performance Optimizer" FontFamily="Segoe UI" FontSize="14"
                       Foreground="#8b949e" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Developed by Bruno Raposo — Brazilian Top Team" FontFamily="Segoe UI" FontSize="13"
                       Foreground="#8b949e" HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- Description -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="13" Foreground="#e6edf3" LineHeight="22"
                           Text="OptiCore is a free, open-source Windows performance optimizer built for gamers and enthusiasts running AMD Ryzen and NVIDIA RTX systems. Every optimization is safe, reversible, and backed by a full registry backup.&#x0a;&#x0a;OptiCore targets low-level Windows settings that impact input latency, frame pacing, interrupt handling, and system responsiveness — the things that matter for competitive gaming and high-performance workloads."/>
            </Border>

            <!-- Links Section -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Support &amp; Links" FontFamily="Segoe UI Semibold" FontSize="14"
                               Foreground="#e6edf3" Margin="0,0,0,12"/>

                    <Button x:Name="KofiBtn" Content="☕  Donate on Ko-fi" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,8" Click="KofiBtn_Click"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="PIX (Brazil): " FontSize="13" Foreground="#8b949e" VerticalAlignment="Center"/>
                        <TextBlock Text="09794587737" FontFamily="Consolas" FontSize="13" Foreground="#e6edf3" VerticalAlignment="Center" Margin="4,0,8,0"/>
                        <Button x:Name="CopyPixBtn" Content="Copy" Style="{StaticResource SecondaryButton}"
                                Padding="10,4" Click="CopyPixBtn_Click"/>
                    </StackPanel>

                    <Separator Style="{StaticResource DarkSeparator}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="GithubBtn" Content="GitHub" Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" Click="GithubBtn_Click"/>
                        <Button x:Name="BugBtn" Content="Report Bug" Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" Click="BugBtn_Click"/>
                        <Button x:Name="FeatureBtn" Content="Request Feature" Style="{StaticResource SecondaryButton}"
                                Click="FeatureBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Disclaimer -->
            <Border Style="{StaticResource CardBorder}" Background="#1a1a00" BorderBrush="#3a3a00" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="⚠ Disclaimer" FontFamily="Segoe UI Semibold" FontSize="13"
                               Foreground="#e67e22" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12" Foreground="#8b949e" LineHeight="20"
                               Text="OptiCore modifies Windows registry settings and system configuration. All changes are backed up automatically. The authors are not responsible for any system instability, data loss, or hardware damage. Use at your own risk. Always maintain a system restore point before applying optimizations."/>
                </StackPanel>
            </Border>

            <TextBlock Text="License: MIT — © 2026 Bruno Raposo / Brazilian Top Team"
                       FontFamily="Segoe UI" FontSize="11" Foreground="#444"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
