    <sys:String x:Key="Category_AiPrivacy">IA e Privacidade</sys:String>
    <sys:String x:Key="AiPrivacy_CategoryNote">Desativa funcionalidades de IA do Windows. Todas reversíveis.</sys:String>
    <sys:String x:Key="Opt_AiCopilotDisable_Name">Desativar Windows Copilot</sys:String>
    <sys:String x:Key="Opt_AiCopilotDisable_Desc">Desativa o assistente de IA Windows Copilot via Política de Grupo para o usuário atual e o sistema. O Copilot inicia processos em segundo plano e envia dados para servidores da Microsoft.</sys:String>
    <sys:String x:Key="Opt_AiRecallDisable_Name">Desativar Windows Recall</sys:String>
    <sys:String x:Key="Opt_AiRecallDisable_Desc">Desativa o Windows Recall (Análise de Dados por IA), que captura e indexa continuamente a atividade da tela. Aplica a política DisableAIDataAnalysis para usuário e sistema.</sys:String>
    <sys:String x:Key="Opt_AiCopilotTaskbarDisable_Name">Remover Botão Copilot da Barra de Tarefas</sys:String>
    <sys:String x:Key="Opt_AiCopilotTaskbarDisable_Desc">Oculta o botão Copilot da barra de tarefas do Windows definindo ShowCopilotButton=0 nas configurações avançadas do Explorer.</sys:String>
    <sys:String x:Key="Opt_AiInputInsightsDisable_Name">Desativar Coleta de Dados de Entrada de Texto</sys:String>
    <sys:String x:Key="Opt_AiInputInsightsDisable_Desc">Desativa a telemetria de personalização de digitação e escrita da Microsoft (TIPC), que envia pressionamentos de tecla para melhorar modelos de previsão.</sys:String>
    <sys:String x:Key="Opt_AiEdgeCopilotDisable_Name">Desativar Copilot no Microsoft Edge</sys:String>
    <sys:String x:Key="Opt_AiEdgeCopilotDisable_Desc">Aplica Política de Grupo do Edge para desativar a barra lateral Copilot e impedir o acesso ao contexto da página. Inofensivo se o Edge não estiver instalado.</sys:String>
    <sys:String x:Key="Opt_AiPaintDisable_Name">Desativar Recursos de IA no Paint</sys:String>
    <sys:String x:Key="Opt_AiPaintDisable_Desc">Desativa os recursos de IA do Microsoft Paint: Criador de Imagens, Cocreator e Preenchimento Generativo. Esses recursos requerem internet e enviam dados de imagem externamente.</sys:String>
    <sys:String x:Key="Opt_AiNotepadDisable_Name">Desativar Reescrita com IA no Bloco de Notas</sys:String>
    <sys:String x:Key="Opt_AiNotepadDisable_Desc">Desativa o recurso de Reescrita com IA do Bloco de Notas do Windows 11, que envia conteúdo de texto para os serviços de IA da Microsoft.</sys:String>
    <sys:String x:Key="Opt_AiGamingCopilotDisable_Name">Desativar Gaming Copilot (Game Bar)</sys:String>
    <sys:String x:Key="Opt_AiGamingCopilotDisable_Desc">Desativa o recurso de IA Copilot integrado ao Xbox Game Bar, impedindo que execute processos de IA em segundo plano durante sessões de jogo.</sys:String>
    <sys:String x:Key="Opt_AiClickToDoDisable_Name">Desativar Click to Do (Ferramenta de Captura)</sys:String>
    <sys:String x:Key="Opt_AiClickToDoDisable_Desc">Desativa o recurso de IA 'Click to Do' da Ferramenta de Captura em PCs Copilot+, impedindo a análise do conteúdo da tela. Inofensivo em sistemas sem esse recurso.</sys:String>
    <sys:String x:Key="Opt_AiOfficeCopilotDisable_Name">Desativar Copilot no Microsoft Office</sys:String>
    <sys:String x:Key="Opt_AiOfficeCopilotDisable_Desc">Aplica Política de Grupo do Office para desativar o Microsoft 365 Copilot. Inofensivo se o Office não estiver instalado; afeta apenas o Office 2024/365 com Copilot.</sys:String>
    <!-- v1.4.0 — Correção de bug + novas otimizações -->
    <sys:String x:Key="Opt_BcdeditPlatformclock_Name">Remover Relógio HPET Forçado (TSC Nativo)</sys:String>
    <sys:String x:Key="Opt_BcdeditPlatformclock_Desc">Remove o sinalizador BCD useplatformclock=true que forçava incorretamente o HPET como fonte de relógio. No AMD Ryzen, o TSC nativo lê em ~3-4 ns vs ~1-2 µs do HPET — remover este sinalizador permite que o Windows use o TSC, ~500× mais rápido.</sys:String>
    <sys:String x:Key="Opt_TdrDelay_Name">Atraso TDR da GPU (8 s)</sys:String>
    <sys:String x:Key="Opt_TdrDelay_Desc">Estende o Timeout Detection and Recovery da GPU para 8 segundos. Evita resets falsos do driver durante picos de carga em GPUs com overclock — o padrão de 2 s pode disparar prematuramente em clocks acima de 3000 MHz.</sys:String>
    <sys:String x:Key="Opt_NvidiaNvtweakGlobal_Name">Bloqueio Global PowerMizer NVIDIA NvTweak</sys:String>
    <sys:String x:Key="Opt_NvidiaNvtweakGlobal_Desc">Define PowerMizerEnable=1 no hive de Software NvTweak do HKLM — uma âncora secundária que sobrevive a reinstalações do driver e complementa o bloqueio no driver nvlddmkm.</sys:String>
    <sys:String x:Key="Opt_PrefetchDisable_Name">Desativar Prefetch (Sistemas NVMe/SSD)</sys:String>
    <sys:String x:Key="Opt_PrefetchDisable_Desc">Define EnablePrefetcher=0 para que o driver de Prefetch pare de gerar leituras de I/O no boot. Redundante em drives NVMe onde o SysMain já está desativado — elimina atividade desnecessária de burst de I/O.</sys:String>
    <sys:String x:Key="Opt_MemoryCompressionDisable_Name">Desativar Compressão de Memória</sys:String>
    <sys:String x:Key="Opt_MemoryCompressionDisable_Desc">Desativa a compressão de RAM do Windows (Disable-MMAgent). Em sistemas com 16 GB+ de RAM, a compressão raramente é ativada, mas ciclos de CPU são gastos de forma proativa — desativar libera esses ciclos para threads de jogos.</sys:String>
    <sys:String x:Key="Opt_MemoryCompressionDisable_Note">Recomendado para sistemas com 16 GB+ de RAM</sys:String>
    <sys:String x:Key="Opt_NetworkThrottlingEnforce_Name">Limitação de Rede Desativada (NetworkThrottlingIndex)</sys:String>
    <sys:String x:Key="Opt_NetworkThrottlingEnforce_Desc">Define NetworkThrottlingIndex=0xFFFFFFFF no perfil do sistema MMCSS. O Windows limita o tráfego de rede não-MMCSS por padrão — desativar evita engasgos durante transições de throttle e garante máximo throughput para jogos.</sys:String>
    <sys:String x:Key="Opt_MmcssProaudio_Name">Perfil MMCSS Pro Audio (Prioridade 1, Alta)</sys:String>
    <sys:String x:Key="Opt_MmcssProaudio_Desc">Ajusta a tarefa MMCSS Pro Audio para Prioridade 1, categoria de agendamento Alta e taxa de clock de 1 ms. Complementa o perfil Games — threads de áudio usam o agendamento Pro Audio, reduzindo a latência de DPC de áudio durante o jogo.</sys:String>
    <sys:String x:Key="Opt_DpsManual_Name">Serviço de Política de Diagnóstico → Manual</sys:String>
    <sys:String x:Key="Opt_DpsManual_Desc">Define o DPS (Diagnostic Policy Service) como inicialização Manual. O DPS roda continuamente para coletar dados de diagnóstico em segundo plano — Manual significa que só inicia quando solicitado explicitamente.</sys:String>
    <sys:String x:Key="Opt_PcasvcManual_Name">Assistente de Compatibilidade de Programas → Manual</sys:String>
    <sys:String x:Key="Opt_PcasvcManual_Desc">Define o PcaSvc (Assistente de Compatibilidade de Programas) como inicialização Manual. Este serviço monitora aplicações em execução em busca de problemas de compatibilidade — sobrecarga desnecessária em um sistema dedicado a jogos.</sys:String>
    <sys:String x:Key="Opt_SpoolerManual_Name">Spooler de Impressão → Manual</sys:String>
    <sys:String x:Key="Opt_SpoolerManual_Desc">Define o Spooler de Impressão como inicialização Manual e o encerra. O Spooler é uma superfície de ataque conhecida e consome RAM em segundo plano — seguro definir como Manual a menos que uma impressora esteja conectada.</sys:String>
    <sys:String x:Key="Opt_SpoolerManual_Note">Reative se precisar imprimir</sys:String>
    <sys:String x:Key="Opt_UsbRoothubSuspend_Name">Suspensão Seletiva do Hub Raiz USB Desativada</sys:String>
    <sys:String x:Key="Opt_UsbRoothubSuspend_Desc">Define EnhancedPowerManagementEnabled=0 em todos os Hubs Raiz USB. Complementa a configuração do controlador xHCI — os Hubs Raiz podem suspender dispositivos conectados de forma independente. Desativar elimina micro-desconexões de dispositivos de entrada.</sys:String>
