    <sys:String x:Key="Category_AiPrivacy">AI &amp; Privacy</sys:String>
    <sys:String x:Key="AiPrivacy_CategoryNote">Disables Windows AI features. All reversible.</sys:String>
    <sys:String x:Key="Opt_AiCopilotDisable_Name">Disable Windows Copilot</sys:String>
    <sys:String x:Key="Opt_AiCopilotDisable_Desc">Disables the Windows Copilot AI assistant via Group Policy for both current user and system. Copilot launches background processes and sends data to Microsoft servers.</sys:String>
    <sys:String x:Key="Opt_AiRecallDisable_Name">Disable Windows Recall</sys:String>
    <sys:String x:Key="Opt_AiRecallDisable_Desc">Disables Windows Recall (AI Data Analysis), which continuously screenshots and indexes your screen activity. Applies the DisableAIDataAnalysis policy for both user and system.</sys:String>
    <sys:String x:Key="Opt_AiCopilotTaskbarDisable_Name">Remove Copilot Button from Taskbar</sys:String>
    <sys:String x:Key="Opt_AiCopilotTaskbarDisable_Desc">Hides the Copilot button from the Windows taskbar by setting ShowCopilotButton=0 in Explorer Advanced settings.</sys:String>
    <sys:String x:Key="Opt_AiInputInsightsDisable_Name">Disable Text Input Data Harvesting</sys:String>
    <sys:String x:Key="Opt_AiInputInsightsDisable_Desc">Disables Microsoft's typing and inking personalization telemetry (TIPC) which sends keystrokes to Microsoft to improve handwriting and typing prediction models.</sys:String>
    <sys:String x:Key="Opt_AiEdgeCopilotDisable_Name">Disable Copilot in Microsoft Edge</sys:String>
    <sys:String x:Key="Opt_AiEdgeCopilotDisable_Desc">Applies Edge Group Policy to disable the Copilot sidebar and prevent Copilot from accessing page context. Harmless if Edge is not installed.</sys:String>
    <sys:String x:Key="Opt_AiPaintDisable_Name">Disable AI Features in Paint</sys:String>
    <sys:String x:Key="Opt_AiPaintDisable_Desc">Disables Microsoft Paint's AI-powered features: Image Creator, Cocreator, and Generative Fill. These features require an internet connection and send image data externally.</sys:String>
    <sys:String x:Key="Opt_AiNotepadDisable_Name">Disable AI Rewrite in Notepad</sys:String>
    <sys:String x:Key="Opt_AiNotepadDisable_Desc">Disables the AI-powered Rewrite feature in Windows 11 Notepad, which sends text content to Microsoft's AI services.</sys:String>
    <sys:String x:Key="Opt_AiGamingCopilotDisable_Name">Disable Gaming Copilot (Game Bar)</sys:String>
    <sys:String x:Key="Opt_AiGamingCopilotDisable_Desc">Disables the AI Copilot feature integrated into Xbox Game Bar, preventing it from running background AI processes during gaming sessions.</sys:String>
    <sys:String x:Key="Opt_AiClickToDoDisable_Name">Disable Click to Do (Snipping Tool)</sys:String>
    <sys:String x:Key="Opt_AiClickToDoDisable_Desc">Disables the 'Click to Do' AI feature that activates via the Snipping Tool on Copilot+ PCs, preventing screen content analysis. Harmless on systems without this feature.</sys:String>
    <sys:String x:Key="Opt_AiOfficeCopilotDisable_Name">Disable Copilot in Microsoft Office</sys:String>
    <sys:String x:Key="Opt_AiOfficeCopilotDisable_Desc">Applies the Office Group Policy to disable Microsoft 365 Copilot. Harmless if Office is not installed; only affects Office 2024/365 with Copilot.</sys:String>
    <!-- v1.4.0 — Bug fix + new optimizations -->
    <sys:String x:Key="Opt_BcdeditPlatformclock_Name">Remove Forced HPET Clock (TSC Native)</sys:String>
    <sys:String x:Key="Opt_BcdeditPlatformclock_Desc">Removes the useplatformclock=true BCD flag that was incorrectly forcing HPET as the system clock source. On AMD Ryzen, the native TSC reads at ~3-4 ns vs HPET's ~1-2 µs — removing this flag lets Windows default to TSC, ~500× faster.</sys:String>
    <sys:String x:Key="Opt_TdrDelay_Name">GPU TDR Delay (8 s)</sys:String>
    <sys:String x:Key="Opt_TdrDelay_Desc">Extends GPU Timeout Detection and Recovery to 8 seconds. Prevents false driver resets during heavy compute spikes on overclocked GPUs — the default 2 s can fire prematurely at 3000 MHz+ core clocks.</sys:String>
    <sys:String x:Key="Opt_NvidiaNvtweakGlobal_Name">NVIDIA NvTweak Global PowerMizer Lock</sys:String>
    <sys:String x:Key="Opt_NvidiaNvtweakGlobal_Desc">Sets PowerMizerEnable=1 in the HKLM Software NvTweak hive — a secondary anchor that survives driver reinstalls and complements the nvlddmkm kernel-driver lock.</sys:String>
    <sys:String x:Key="Opt_PrefetchDisable_Name">Disable Prefetch (NVMe/SSD Systems)</sys:String>
    <sys:String x:Key="Opt_PrefetchDisable_Desc">Sets EnablePrefetcher=0 so the Prefetch driver stops generating boot-time I/O reads. Redundant on NVMe drives where SysMain is already disabled — eliminating it removes unnecessary I/O burst activity.</sys:String>
    <sys:String x:Key="Opt_MemoryCompressionDisable_Name">Disable Memory Compression</sys:String>
    <sys:String x:Key="Opt_MemoryCompressionDisable_Desc">Disables Windows RAM compression (Disable-MMAgent). On systems with 16 GB+ RAM, compression rarely activates but CPU cycles are spent proactively scanning — disabling reclaims that overhead for game threads.</sys:String>
    <sys:String x:Key="Opt_MemoryCompressionDisable_Note">Recommended for systems with 16 GB+ RAM</sys:String>
    <sys:String x:Key="Opt_NetworkThrottlingEnforce_Name">Network Throttling Off (NetworkThrottlingIndex)</sys:String>
    <sys:String x:Key="Opt_NetworkThrottlingEnforce_Desc">Sets NetworkThrottlingIndex=0xFFFFFFFF in the MMCSS SystemProfile. Windows throttles non-MMCSS network traffic by default — disabling prevents stutter from throttle transitions and ensures maximum gaming throughput.</sys:String>
    <sys:String x:Key="Opt_MmcssProaudio_Name">MMCSS Pro Audio Profile (Priority 1, High)</sys:String>
    <sys:String x:Key="Opt_MmcssProaudio_Desc">Tunes the MMCSS Pro Audio task to Priority 1, High scheduling category, and 1 ms clock rate. Complements the Games profile — audio threads use Pro Audio scheduling, and tuning it reduces DPC latency during gameplay.</sys:String>
    <sys:String x:Key="Opt_DpsManual_Name">Diagnostic Policy Service → Manual</sys:String>
    <sys:String x:Key="Opt_DpsManual_Desc">Sets DPS (Diagnostic Policy Service) to Manual start. DPS runs continuously to collect background diagnostic data — Manual means it only launches when explicitly triggered, not as a persistent daemon.</sys:String>
    <sys:String x:Key="Opt_PcasvcManual_Name">Program Compatibility Assistant → Manual</sys:String>
    <sys:String x:Key="Opt_PcasvcManual_Desc">Sets PcaSvc (Program Compatibility Assistant) to Manual start. This service monitors all running applications for compatibility issues at runtime — unnecessary overhead on a gaming/performance system.</sys:String>
    <sys:String x:Key="Opt_SpoolerManual_Name">Print Spooler → Manual</sys:String>
    <sys:String x:Key="Opt_SpoolerManual_Desc">Sets Spooler (Print Spooler) to Manual start and stops it. The Print Spooler is a well-known attack surface and consumes background RAM — safe to set Manual unless a printer is connected.</sys:String>
    <sys:String x:Key="Opt_SpoolerManual_Note">Re-enable if you need to print</sys:String>
    <sys:String x:Key="Opt_UsbRoothubSuspend_Name">USB Root Hub Selective Suspend Off</sys:String>
    <sys:String x:Key="Opt_UsbRoothubSuspend_Desc">Sets EnhancedPowerManagementEnabled=0 on all USB Root Hubs. Complements the xHCI controller setting — Root Hubs can independently suspend connected devices. Disabling eliminates input device micro-disconnects.</sys:String>
</ResourceDictionary>
