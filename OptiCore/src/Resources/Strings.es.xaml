    <sys:String x:Key="Category_AiPrivacy">IA y Privacidad</sys:String>
    <sys:String x:Key="AiPrivacy_CategoryNote">Desactiva las funciones de IA de Windows. Todas reversibles.</sys:String>
    <sys:String x:Key="Opt_AiCopilotDisable_Name">Desactivar Windows Copilot</sys:String>
    <sys:String x:Key="Opt_AiCopilotDisable_Desc">Desactiva el asistente de IA Windows Copilot mediante Directiva de grupo para el usuario actual y el sistema. Copilot ejecuta procesos en segundo plano y envía datos a servidores de Microsoft.</sys:String>
    <sys:String x:Key="Opt_AiRecallDisable_Name">Desactivar Windows Recall</sys:String>
    <sys:String x:Key="Opt_AiRecallDisable_Desc">Desactiva Windows Recall (Análisis de datos con IA), que captura e indexa continuamente la actividad de pantalla. Aplica la directiva DisableAIDataAnalysis para el usuario y el sistema.</sys:String>
    <sys:String x:Key="Opt_AiCopilotTaskbarDisable_Name">Eliminar el Botón Copilot de la Barra de Tareas</sys:String>
    <sys:String x:Key="Opt_AiCopilotTaskbarDisable_Desc">Oculta el botón Copilot de la barra de tareas de Windows estableciendo ShowCopilotButton=0 en la configuración avanzada del Explorador.</sys:String>
    <sys:String x:Key="Opt_AiInputInsightsDisable_Name">Desactivar Recopilación de Datos de Entrada de Texto</sys:String>
    <sys:String x:Key="Opt_AiInputInsightsDisable_Desc">Desactiva la telemetría de personalización de escritura de Microsoft (TIPC), que envía pulsaciones de teclas para mejorar los modelos de predicción de escritura.</sys:String>
    <sys:String x:Key="Opt_AiEdgeCopilotDisable_Name">Desactivar Copilot en Microsoft Edge</sys:String>
    <sys:String x:Key="Opt_AiEdgeCopilotDisable_Desc">Aplica Directiva de grupo de Edge para desactivar la barra lateral de Copilot e impedir el acceso al contexto de la página. Sin efecto si Edge no está instalado.</sys:String>
    <sys:String x:Key="Opt_AiPaintDisable_Name">Desactivar Funciones de IA en Paint</sys:String>
    <sys:String x:Key="Opt_AiPaintDisable_Desc">Desactiva las funciones de IA de Microsoft Paint: Creador de imágenes, Cocreator y Relleno generativo. Estas funciones requieren internet y envían datos de imagen externamente.</sys:String>
    <sys:String x:Key="Opt_AiNotepadDisable_Name">Desactivar Reescritura con IA en el Bloc de Notas</sys:String>
    <sys:String x:Key="Opt_AiNotepadDisable_Desc">Desactiva la función de Reescritura con IA del Bloc de notas de Windows 11, que envía contenido de texto a los servicios de IA de Microsoft.</sys:String>
    <sys:String x:Key="Opt_AiGamingCopilotDisable_Name">Desactivar Gaming Copilot (Barra de Juego)</sys:String>
    <sys:String x:Key="Opt_AiGamingCopilotDisable_Desc">Desactiva la función de IA Copilot integrada en la Barra de juego de Xbox, evitando que ejecute procesos de IA en segundo plano durante las sesiones de juego.</sys:String>
    <sys:String x:Key="Opt_AiClickToDoDisable_Name">Desactivar Click to Do (Herramienta de Recorte)</sys:String>
    <sys:String x:Key="Opt_AiClickToDoDisable_Desc">Desactiva la función de IA 'Click to Do' de la Herramienta de recorte en PCs Copilot+, que impide el análisis del contenido de la pantalla. Sin efecto en sistemas sin esta función.</sys:String>
    <sys:String x:Key="Opt_AiOfficeCopilotDisable_Name">Desactivar Copilot en Microsoft Office</sys:String>
    <sys:String x:Key="Opt_AiOfficeCopilotDisable_Desc">Aplica la Directiva de grupo de Office para desactivar Microsoft 365 Copilot. Sin efecto si Office no está instalado; solo afecta a Office 2024/365 con Copilot.</sys:String>
    <!-- v1.4.0 — Corrección de error + nuevas optimizaciones -->
    <sys:String x:Key="Opt_BcdeditPlatformclock_Name">Eliminar Reloj HPET Forzado (TSC Nativo)</sys:String>
    <sys:String x:Key="Opt_BcdeditPlatformclock_Desc">Elimina el indicador BCD useplatformclock=true que forzaba incorrectamente el HPET como fuente de reloj. En AMD Ryzen, el TSC nativo lee en ~3-4 ns frente a ~1-2 µs del HPET — eliminar este indicador permite que Windows use TSC, ~500× más rápido.</sys:String>
    <sys:String x:Key="Opt_TdrDelay_Name">Retraso TDR de GPU (8 s)</sys:String>
    <sys:String x:Key="Opt_TdrDelay_Desc">Extiende el Timeout Detection and Recovery de la GPU a 8 segundos. Evita reinicios falsos del controlador durante picos de carga en GPUs con overclock — el valor predeterminado de 2 s puede dispararse prematuramente a más de 3000 MHz de núcleo.</sys:String>
    <sys:String x:Key="Opt_NvidiaNvtweakGlobal_Name">Bloqueo Global PowerMizer NVIDIA NvTweak</sys:String>
    <sys:String x:Key="Opt_NvidiaNvtweakGlobal_Desc">Establece PowerMizerEnable=1 en el hive de Software NvTweak de HKLM — un anclaje secundario que sobrevive a reinstalaciones del controlador y complementa el bloqueo en el driver nvlddmkm.</sys:String>
    <sys:String x:Key="Opt_PrefetchDisable_Name">Desactivar Prefetch (Sistemas NVMe/SSD)</sys:String>
    <sys:String x:Key="Opt_PrefetchDisable_Desc">Establece EnablePrefetcher=0 para que el controlador de Prefetch deje de generar lecturas de E/S en el arranque. Redundante en unidades NVMe donde SysMain ya está desactivado — elimina actividad de ráfaga de E/S innecesaria.</sys:String>
    <sys:String x:Key="Opt_MemoryCompressionDisable_Name">Desactivar Compresión de Memoria</sys:String>
    <sys:String x:Key="Opt_MemoryCompressionDisable_Desc">Desactiva la compresión de RAM de Windows (Disable-MMAgent). En sistemas con 16 GB+ de RAM, la compresión rara vez se activa pero se gastan ciclos de CPU de forma proactiva — desactivar libera esos ciclos para subprocesos de juego.</sys:String>
    <sys:String x:Key="Opt_MemoryCompressionDisable_Note">Recomendado para sistemas con 16 GB+ de RAM</sys:String>
    <sys:String x:Key="Opt_NetworkThrottlingEnforce_Name">Limitación de Red Desactivada (NetworkThrottlingIndex)</sys:String>
    <sys:String x:Key="Opt_NetworkThrottlingEnforce_Desc">Establece NetworkThrottlingIndex=0xFFFFFFFF en el perfil del sistema MMCSS. Windows limita el tráfico de red no MMCSS de forma predeterminada — desactivar evita el tartamudeo por transiciones de limitación y garantiza el máximo rendimiento para juegos.</sys:String>
    <sys:String x:Key="Opt_MmcssProaudio_Name">Perfil MMCSS Pro Audio (Prioridad 1, Alta)</sys:String>
    <sys:String x:Key="Opt_MmcssProaudio_Desc">Ajusta la tarea MMCSS Pro Audio a Prioridad 1, categoría de programación Alta y tasa de reloj de 1 ms. Complementa el perfil Games — los subprocesos de audio usan la programación Pro Audio, reduciendo la latencia DPC de audio durante el juego.</sys:String>
    <sys:String x:Key="Opt_DpsManual_Name">Servicio de Directiva de Diagnóstico → Manual</sys:String>
    <sys:String x:Key="Opt_DpsManual_Desc">Establece DPS (Servicio de Directiva de Diagnóstico) en inicio Manual. DPS se ejecuta continuamente para recopilar datos de diagnóstico en segundo plano — Manual significa que solo se inicia cuando se solicita explícitamente.</sys:String>
    <sys:String x:Key="Opt_PcasvcManual_Name">Asistente de Compatibilidad de Programas → Manual</sys:String>
    <sys:String x:Key="Opt_PcasvcManual_Desc">Establece PcaSvc (Asistente de compatibilidad de programas) en inicio Manual. Este servicio monitorea todas las aplicaciones en ejecución en busca de problemas de compatibilidad — sobrecarga innecesaria en un sistema de juego/rendimiento.</sys:String>
    <sys:String x:Key="Opt_SpoolerManual_Name">Cola de Impresión → Manual</sys:String>
    <sys:String x:Key="Opt_SpoolerManual_Desc">Establece el Spooler de impresión en inicio Manual y lo detiene. La Cola de impresión es una superficie de ataque conocida y consume RAM en segundo plano — seguro configurar como Manual a menos que haya una impresora conectada.</sys:String>
    <sys:String x:Key="Opt_SpoolerManual_Note">Volver a activar si necesitas imprimir</sys:String>
    <sys:String x:Key="Opt_UsbRoothubSuspend_Name">Suspensión Selectiva del Hub Raíz USB Desactivada</sys:String>
    <sys:String x:Key="Opt_UsbRoothubSuspend_Desc">Establece EnhancedPowerManagementEnabled=0 en todos los Hubs Raíz USB. Complementa la configuración del controlador xHCI — los Hubs Raíz pueden suspender dispositivos conectados de forma independiente. Desactivar elimina micro-desconexiones de dispositivos de entrada.</sys:String>
</ResourceDictionary>
