    <sys:String x:Key="About_GitHub">GitHub</sys:String>
    <sys:String x:Key="About_ReportBug">Fehler Melden</sys:String>
    <sys:String x:Key="About_RequestFeature">Funktion Anfragen</sys:String>
    <sys:String x:Key="About_Disclaimer">HAFTUNGSAUSSCHLUSS: OptiCore ändert die Windows-Registrierung und Systemeinstellungen. Halten Sie immer Backups. Die Autoren haften nicht für Instabilitäten. Verwendung auf eigenes Risiko.</sys:String>
